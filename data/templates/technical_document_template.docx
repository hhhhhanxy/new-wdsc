<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<w:document xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">
    <w:body>
        <w:p>
            <w:r>
                <w:t>航空作动产品技术文档</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>文档编号：{{document_id}}</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>版本：{{version}}</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>日期：{{date}}</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>摘要</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>{{abstract}}</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>引言</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>{{introduction}}</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>设计方案</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>{{design_scheme}}</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>验证结果</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>{{verification_results}}</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>结论</w:t>
            </w:r>
        </w:p>
        <w:p>
            <w:r>
                <w:t>{{conclusion}}</w:t>
            </w:r>
        </w:p>
    </w:body>
</w:document>